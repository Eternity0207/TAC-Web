PORT=3003
NODE_ENV=development

# Security
JWT_SECRET=change-me-to-a-long-random-secret
CREDENTIALS_ENCRYPTION_KEY=change-me-to-a-32-char-secret

# Storage backend
BACKEND_STORAGE=postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_PROFILE_PHOTOS_BUCKET=profile-photos

# PayU
PAYU_MERCHANT_KEY=your-payu-merchant-key
PAYU_MERCHANT_SALT=your-payu-merchant-salt
PAYU_AUTH_HEADER=your-payu-auth-header

# UPI + webhook
UPI_ID=your-upi-id@bank
UPI_PAYEE_NAME=The Awla Company
N8N_WEBHOOK_SECRET=your-n8n-webhook-secret

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
EMAIL_FROM=orders@theawlacompany.com

# Initial admin bootstrap
ADMIN_EMAIL=admin@theawlacompany.com
ADMIN_PASSWORD=change-this

# URLs
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:5173
BACKEND_URL=http://localhost:3003
BACKEND_UPLOADS_URL=http://localhost:3003/uploads

# CORS origins (comma separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3003,http://localhost:5173

# Optional social media analytics integration
META_ACCESS_TOKEN=
META_FB_PAGE_ID=
