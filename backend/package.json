{
  "name": "unified-oms-backend",
  "version": "1.0.0",
  "description": "Unified Order Management System Backend with Admin Panel",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "list-users": "node list-users.js list",
    "user:add": "node list-users.js add",
    "user:update": "node list-users.js update",
    "user:remove": "node list-users.js remove",
    "build:frontend": "cd ../admin_frontend_oms-main && npm run build && cp -r dist/* ../unified-backend/public/",
    "init-admin": "node -e \"require('dotenv').config(); const axios = require('axios'); const base=(process.env.BACKEND_URL || process.env.ADMIN_URL || 'https://admin.theawlacompany.com').replace(/\\/$/, ''); axios.post(base + '/auth/init').then(r => console.log(r.data)).catch(e => console.error(e.response?.data || e.message));\"",
    "smtp:test": "node scripts/smtp-test.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "migrate": "ts-node migration/run.ts"
  },
  "keywords": [
    "oms",
    "order management",
    "admin panel",
    "express",
    "google-sheets",
    "typescript"
  ],
  "author": "The Awla Company",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.6.2",
    "bcryptjs": "^3.0.3",
    "canvas": "^3.2.0",
    "cors": "^2.8.6",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^6.9.7",
    "pdfkit": "^0.15.0",
    "qrcode": "^1.5.3",
    "uuid": "^9.0.1",
    "@supabase/supabase-js": "^2.57.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/crypto-js": "^4.2.1",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.10.4",
    "@types/nodemailer": "^6.4.14",
    "@types/pdfkit": "^0.17.4",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^9.0.7",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
